# 工地管理系统 - 环境变量配置模板
# =============================================
# 复制此文件为 .env.local 并填入你的真实值
# =============================================

# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=你的Supabase项目URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的Supabase匿名密钥
SUPABASE_SERVICE_ROLE_KEY=你的Supabase服务角色密钥

# 七牛云配置（可选，如不使用图片功能可留空）
QINIU_ACCESS_KEY=你的七牛云AccessKey
QINIU_SECRET_KEY=你的七牛云SecretKey
QINIU_BUCKET_NAME=你的七牛云存储空间名称
QINIU_DOMAIN=你的七牛云下载域名（如已配置自定义域名）

# =============================================
# 获取方式：
# 1. Supabase: https://supabase.com/dashboard
# 2. 七牛云: https://www.qiniu.com
# =============================================
